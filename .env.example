# Copy file ini menjadi .env dan isi dengan nilai yang sesuai

PORT=3001
JWT_SECRET=ganti-dengan-secret-key-yang-kuat

# Email (SMTP) — untuk notifikasi email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password

# API Key untuk Google Form Apps Script
# Harus sama dengan CONFIG.API_KEY di google-form-apps-script.gs
FORM_API_KEY=roombook-form-key-2024

